#!/usr/bin/env python3
import sys
import os
sys.path.insert(0, '/usr/lib/python3/dist-packages')

try:
    from locale_tester.main import main
    main()
except ImportError:
    try:
        from locale_tester.app import main
        main()
    except ImportError:
        print("Error: Cannot find main module for locale-tester", file=sys.stderr)
        sys.exit(1)
